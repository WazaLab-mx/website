# -------- Calculator / AI ROI assessment --------

# Google Gemini API key — powers the quiz question + summary generation.
# Get one at: https://aistudio.google.com/app/apikey
# NEVER prefix with NEXT_PUBLIC_ — server-side only.
GEMINI_API_KEY=your_gemini_api_key_here

# Resend API key — sends the ROI report email to the user.
# Get one at: https://resend.com → API Keys.
# Leave unset to skip email delivery (leads will still be stored).
RESEND_API_KEY=re_your_resend_api_key_here

# Sender identity for the report email. Must be a domain you have
# verified in Resend. In dev you can use "WAZA <onboarding@resend.dev>"
# which works without verification but only delivers to your own inbox.
RESEND_FROM_EMAIL=WAZA <reports@wazalab.mx>

# Reply-to address users will see. Route replies to a monitored inbox.
CALCULATOR_REPLY_TO=hello@wazalab.mx

# -------- Lead storage (Google Sheets) --------
#
# Setup (one-time):
# 1. Go to https://console.cloud.google.com → create/select a project.
# 2. Enable the Google Sheets API.
# 3. IAM & Admin → Service Accounts → Create. Pick a name, skip roles.
# 4. Open the service account → Keys → Add Key → JSON. Save the file.
# 5. Create a Google Sheet. Share it with the service account's email
#    (client_email field in the JSON) with Editor access.
# 6. Copy the spreadsheet ID from its URL (the long string between
#    /d/ and /edit).
# 7. Fill in the vars below. For the private key, copy the value and
#    wrap it in double quotes so the `\n` escapes are preserved.
#
# Leave all three unset to skip lead storage (only emails are sent).

GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_SHEETS_CLIENT_EMAIL=waza-leads@your-project.iam.gserviceaccount.com
# Paste the private_key field from the downloaded service-account JSON,
# wrapped in double quotes so the "\n" escape sequences survive.
# It looks like:  "BEGIN PRIVATE KEY...base64 body...END PRIVATE KEY".
GOOGLE_SHEETS_PRIVATE_KEY=your_service_account_private_key_here

# Optional: the tab/sheet name inside the spreadsheet. Default "Leads".
GOOGLE_SHEETS_TAB_NAME=Leads
