# -------- Calculator / AI ROI assessment --------

# Google Gemini API key — powers the quiz question + summary generation.
# Get one at: https://aistudio.google.com/app/apikey
# NEVER prefix with NEXT_PUBLIC_ — server-side only.
GEMINI_API_KEY=your_gemini_api_key_here

# Resend API key — sends the ROI report email to the user.
# Get one at: https://resend.com → API Keys.
# Leave unset to skip email delivery (leads will still be stored).
RESEND_API_KEY=re_your_resend_api_key_here

# Sender identity for the report email. Must be a domain you have
# verified in Resend. In dev you can use "WAZA <onboarding@resend.dev>"
# which works without verification but only delivers to your own inbox.
RESEND_FROM_EMAIL=WAZA <reports@wazalab.mx>

# Reply-to address users will see. Route replies to a monitored inbox.
CALCULATOR_REPLY_TO=hello@wazalab.mx

# -------- Lead storage (Supabase) --------

# Supabase project URL and service_role key. Used server-side to insert
# calculator leads into public.calculator_leads.
# Run supabase/migrations/20260422_calculator_leads.sql once in the SQL
# editor to create the table.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
